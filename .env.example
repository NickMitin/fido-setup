# FIDO Echo-Conference Configuration
# Copy to .env and fill in your uplink details
# cp .env.example .env

# Your identity (get AKA from your uplink)
LINK_NAME=FidoNet
LINK_DOMAIN=fidonet
YOUR_NAME=Your Name
YOUR_AKA=2:240/5853.5
YOUR_SYSTEM=FIDO-Echo 2026
YOUR_LOCATION=City, Country
YOUR_HOSTNAME=your.domain.com

# Uplink connection (required for echomail)
UPLINK_HOST=uplink.example.com
UPLINK_PORT=24554
UPLINK_AKA=2:240/5853

# Passwords (from uplink - keep secret!)
SESSION_PASSWORD=your_binkp_password
PACKET_PASSWORD=
AREAFIX_PASSWORD=
FILEFIX_PASSWORD=

# Web console (change default!)
WEB_PASSWORD=fidian
ENABLE_TTYD=1

# Timezone
TZ=Europe/Berlin

# Telegram → FidoNet bridge (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=          # From https://my.telegram.org — for fetch_latest_posts
TELEGRAM_API_HASH=
FIDO_ECHO_AREA=NICKMITIN.SAYS
FIDO_SENDER_NAME=TG-Bot
TELEGRAM_CHANNEL_ID=
